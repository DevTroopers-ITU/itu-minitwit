{
  "uid": "logging-dashboard",
  "title": "Minitwit Logging Dashboard",
  "tags": ["logging", "loki"],
  "timezone": "browser",
  "schemaVersion": 42,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Log Volume by Service",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki-uid" },
      "targets": [
        {
          "expr": "sum by (swarm_service) (count_over_time({swarm_service=~\".+\"} [1m]))",
          "refId": "A"
        }
      ],
      "options": {
        "stacking": "normal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 80
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "All Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "loki-uid" },
      "targets": [
        {
          "expr": "{swarm_service=~\".+\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 3,
      "title": "Webserver Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki-uid" },
      "targets": [
        {
          "expr": "{swarm_service=\"webserver\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 4,
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "loki", "uid": "loki-uid" },
      "targets": [
        {
          "expr": "{swarm_service=~\".+\"} |~ \"(?i)(error|fatal|panic)\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
